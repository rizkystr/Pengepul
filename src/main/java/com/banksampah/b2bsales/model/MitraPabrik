package com.banksampah.b2bsales.model;

public class MitraPabrik {
    private String id;
    private String namaPerusahaan;
    private String penanggungJawab;
    private String statusKontrak; // "AKTIF" atau "TIDAK_AKTIF"

    public MitraPabrik() {}

    public MitraPabrik(String id, String namaPerusahaan, String penanggungJawab, String statusKontrak) {
        this.id = id;
        this.namaPerusahaan = namaPerusahaan;
        this.penanggungJawab = penanggungJawab;
        this.statusKontrak = statusKontrak;
    }

    // Getter & Setter
    public String getId() { return id; }
    public void setId(String id) { this.id = id; }
    public String getNamaPerusahaan() { return namaPerusahaan; }
    public void setNamaPerusahaan(String namaPerusahaan) { this.namaPerusahaan = namaPerusahaan; }
    public String getPenanggungJawab() { return penanggungJawab; }
    public void setPenanggungJawab(String penanggungJawab) { this.penanggungJawab = penanggungJawab; }
    public String getStatusKontrak() { return statusKontrak; }
    public void setStatusKontrak(String statusKontrak) { this.statusKontrak = statusKontrak; }

    @Override
    public String toString() { return namaPerusahaan + " [" + statusKontrak + "]"; }
}
